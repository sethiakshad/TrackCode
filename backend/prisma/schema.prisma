/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model public_users {
  id                                              String                      @id @db.Uuid
  username                                        String                      @unique
  email                                           String                      @unique
  avatar                                          String?
  bio                                             String?
  role                                            user_role                   @default(user)
  is_verified                                     Boolean                     @default(false)
  is_active                                       Boolean                     @default(true)
  created_at                                      DateTime                    @default(now()) @db.Timestamptz(6)
  updated_at                                      DateTime                    @default(now()) @db.Timestamptz(6)
  ai_reports                                      ai_reports[]
  audit_logs                                      audit_logs[]
  bookmarks                                       bookmarks[]
  codeforces_profiles                             codeforces_profiles?
  contest_history                                 contest_history[]
  contest_predictions                             contest_predictions[]
  conversation_participants                       conversation_participants[]
  daily_stats                                     daily_stats[]
  dashboard_summary                               dashboard_summary?
  email_verifications                             email_verifications[]
  friend_requests_friend_requests_receiverTousers friend_requests[]           @relation("friend_requests_receiverTousers")
  friend_requests_friend_requests_senderTousers   friend_requests[]           @relation("friend_requests_senderTousers")
  friends_friends_friend_idTousers                friends[]                   @relation("friends_friend_idTousers")
  friends_friends_user_idTousers                  friends[]                   @relation("friends_user_idTousers")
  github_profiles                                 github_profiles?
  goals                                           goals[]
  learning_paths                                  learning_paths[]
  leetcode_profiles                               leetcode_profiles?
  messages                                        messages[]
  monthly_stats                                   monthly_stats[]
  notifications                                   notifications[]
  password_resets                                 password_resets[]
  recommendations                                 recommendations[]
  refresh_tokens                                  public_refresh_tokens[]
  roadmaps                                        roadmaps[]
  topic_mastery                                   topic_mastery[]
  user_achievements                               user_achievements[]
  user_badges                                     user_badges[]
  user_problem_history                            user_problem_history[]
  user_settings                                   user_settings?
  users                                           auth_users                  @relation(fields: [id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  weekly_stats                                    weekly_stats[]
  xp_history                                      xp_history[]

  @@map("users")
  @@schema("public")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model weekly_stats {
  id              String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id         String       @db.Uuid
  week_start      DateTime     @db.Date
  problems_solved Int          @default(0)
  contests_played Int          @default(0)
  commits         Int          @default(0)
  xp_earned       Int          @default(0)
  study_minutes   Int          @default(0)
  users           public_users @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, week_start])
  @@index([user_id, week_start], map: "idx_weekly_stats_user_week")
  @@schema("public")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model xp_history {
  id         String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id    String       @db.Uuid
  amount     Int
  reason     String?
  source     String?
  created_at DateTime     @default(now()) @db.Timestamptz(6)
  users      public_users @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([user_id], map: "idx_xp_history_user_id")
  @@schema("public")
}

