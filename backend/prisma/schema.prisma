  id           String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name         String         @unique
  problem_tags problem_tags[]

  @@schema("public")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model topic_mastery {
  user_id       String       @db.Uuid
  topic         String
  solved        Int          @default(0)
  accuracy      Decimal      @default(0) @db.Decimal(5, 2)
  mastery_score Decimal      @default(0) @db.Decimal(5, 2)
  updated_at    DateTime     @default(now()) @db.Timestamptz(6)
  users         public_users @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([user_id, topic])
  @@schema("public")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model user_achievements {
  user_id        String       @db.Uuid
  achievement_id String       @db.Uuid
  earned_at      DateTime     @default(now()) @db.Timestamptz(6)
  achievements   achievements @relation(fields: [achievement_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users          public_users @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([user_id, achievement_id])
  @@schema("public")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model user_badges {
  user_id   String       @db.Uuid
  badge_id  String       @db.Uuid
  earned_at DateTime     @default(now()) @db.Timestamptz(6)
  badges    badges       @relation(fields: [badge_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users     public_users @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([user_id, badge_id])
  @@schema("public")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model user_problem_history {
  id          String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id     String         @db.Uuid
  problem_id  String         @db.Uuid
  status      problem_status @default(unsolved)
  attempts    Int            @default(0)
  solved_time Int?
  bookmarked  Boolean        @default(false)
  solved_at   DateTime?      @db.Timestamptz(6)
  problems    problems       @relation(fields: [problem_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users       public_users   @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, problem_id])
  @@index([status], map: "idx_user_problem_history_status")
  @@index([user_id], map: "idx_user_problem_history_user_id")
  @@schema("public")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model user_settings {
  user_id             String             @id @db.Uuid
  theme               theme_preference   @default(system)
  email_notifications Boolean            @default(true)
  profile_visibility  profile_visibility @default(public)
  language            String             @default("en")
  timezone            String             @default("UTC")
  updated_at          DateTime           @default(now()) @db.Timestamptz(6)
  users               public_users       @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@schema("public")
}

